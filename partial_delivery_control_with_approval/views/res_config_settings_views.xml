<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="partial_payment_control_view_form_settings" model="ir.ui.view">
        <field name="name">partial.payment.config.view.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='operations_setting_container']" position="inside">
                <group>
                    <setting id="payment_control_users" help="Set Who can approve partial payments">
                        <field name="payment_control_users" widget="many2many_tags"/>
                    </setting>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
