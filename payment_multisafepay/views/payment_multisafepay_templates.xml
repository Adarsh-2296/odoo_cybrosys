<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="payment_multisafepay_redirect_form">
    <form t-att-action="api_url" method="post">
        <input type="hidden" name="reference"
               t-att-value="reference"/>
        <button type="submit"
                class="btn btn-primary d-none">Pay</button>
    </form>
    </template>
    <template id="payment_multisafepay_inline_form">
    <div t-attf-id="multisafepay-direct-container-{{provider_id}}">
        <select id="multisafepay_simulated_state" class="form-select">
            <option value="done">Successful</option>
            <option value="cancel">Cancelled</option>
        </select>
    </div>
    </template>


</odoo>
