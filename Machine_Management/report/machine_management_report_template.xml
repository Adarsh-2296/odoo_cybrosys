<?xml version="1.0" encoding="utf-8"?>
<odoo>
   <data>
       <template id="report_machine_management_document">
           <t t-call="web.html_container">
               <t t-foreach="docs" t-as="o">
                   <t t-call="web.external_layout">
                       <div class="page">
                           <h2>Order Report: <span t-field="o.name"/></h2>
                           <p>Customer: <span t-field="o.partner_id.name"/></p>
                           <p>Order Date: <span t-field="o.date_of_purchase"/></p>

                           <h3>Order Lines:</h3>
                           <table class="table table-sm">
                               <thead>
                                   <tr>
                                       <th>Product</th>
                                       <th>Quantity</th>
                                       <th>Unit</th>
                                   </tr>
                               </thead>
                               <tbody>
                                   <tr t-foreach="o.order_line_ids" t-as="line">
                                       <td><span t-field="line.product_id.name"/></td>
                                       <td><span t-field="line.quantity"/></td>
                                       <td><span t-field="line.product_uom_id"/></td>
                                   </tr>
                               </tbody>
                           </table>
                       </div>
                   </t>
               </t>
           </t>
       </template>
   </data>

    <data>
       <template id="report_machine_transfer_document">
           <t t-call="web.html_container">
               <t t-foreach="docs" t-as="o">
                   <t t-call="web.external_layout">
                       <div class="page">
                           <h2>Machine : <span t-field="o.machine_id.name"/></h2>
                           <p>Transfer Type : <span t-field="o.transfer_type"/></p>
                           <p>Customer : <span t-field="o.partner_id.name"/></p>
                           <p>Transfer From : <span t-field="o.transfer_date"/></p>
                           <p>Transfer To : <span t-field="o.transfer_to_date"/></p>
                       </div>
                   </t>
               </t>
           </t>
       </template>
   </data>

   <data>
    <template id="transfer_table">
        <t t-call="web.external_layout">
           <t t-call="web.html_container">
               <div class="page">
               <header>
                   <style>
                       table, th, td {
                       border: 1px solid black;
                       }

                   </style>
               </header>
                   <t t-if="docs[1] == 1 ">
                            <h2 t-if="docs[-1] == 0 " >Machine : <span t-field="docs[2].machine_id.name"/>| Type : Install</h2>
                            <h2 t-if="docs[-1] == 1 " >Customer : <span t-field="docs[2].partner_id.name"/>| Type : Install</h2>
                   </t>
                   <t t-if="docs[-1] == 2">
                            <h2 t-if="docs[1] == 1 " >Type : Install</h2>
                   </t>
                           <table class="table table-sm">
                               <t t-if="docs[1] == 1 ">
                               <thead>
                                   <tr>
                                       <th>Transfer Code</th>
                                       <th t-if="docs[-1] != 0 ">Machine</th>
                                       <th t-if="docs[-1] != 1 ">Customer</th>
                                       <th>Transfer From</th>
                                       <th>Transfer Till</th>
                                   </tr>
                               </thead>
                               </t>
                               <t t-foreach="docs[2:-1]" t-as="o">
                               <t t-if="o.transfer_type == 'install'">
                               <tbody>
                                   <tr>
                                       <td><span t-field="o.sequence_no_transfer"/></td>
                                       <td t-if="docs[-1] != 0 "><span t-field="o.machine_id.name"/></td>
                                       <td t-if="docs[-1] != 1 "><span t-field="o.partner_id.name"/></td>
                                       <td><span t-field="o.transfer_date"/></td>
                                       <td><span t-field="o.transfer_to_date"/></td>
                                   </tr>
                               </tbody>
                                   </t>
                               </t>
                           </table><br/>
                   <t t-if="docs[0] == 0 ">
                   <h2 t-if="docs[-1] == 0 " >Machine : <span t-field="docs[2].machine_id.name"/>| Type : Remove</h2>
                   </t>
                   <t t-if="docs[-1] != 0">
                   <h2 t-if="docs[0] == 0 " >Type : Remove</h2>
                   </t>
                   <table class="table table-sm">
                       <t t-if="docs[0] == 0 ">
                               <thead>
                                   <tr>
                                       <th>Transfer Code</th>
                                       <th t-if="docs[-1] != 0 ">Machine</th>
                                       <th>Transfer From</th>
                                       <th>Transfer Till</th>
                                   </tr>
                               </thead>
                       </t>
                               <t t-foreach="docs[2:-1]" t-as="o">
                                   <t t-if="o.transfer_type == 'remove'">
                               <tbody>
                                   <tr>
                                       <td><span t-field="o.sequence_no_transfer"/></td>
                                       <td t-if="docs[-1] != 0 "><span t-field="o.machine_id.name"/></td>
                                       <td><span t-field="o.transfer_date"/></td>
                                       <td><span t-field="o.transfer_to_date"/></td>
                                   </tr>
                               </tbody>
                                   </t>
                               </t>
                           </table>
               </div>
                   </t>
               </t>
       </template>
   </data>
</odoo>


