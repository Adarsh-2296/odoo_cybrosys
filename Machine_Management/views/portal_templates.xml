<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template
        id="machines"
        name="Machines"
        inherit_id="portal.portal_my_home"
    >
        <div id="portal_common_category" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/portal/static/src/img/portal-addresses.svg'"/>
                <t t-set="title">Machines</t>
                <t t-set="text">View all the machines</t>
                <t t-set="url" t-value="'/website/machine'"/>
                <t t-set="config_card" t-value="True"/>
            </t>
        </div>
    </template>
    <template id="portal_machine_details" name="Machine Management Details">
        <t t-call="portal.portal_layout">
        <t t-set="breadcrumbs_searchbar" t-value="True"/>

        <t t-call="portal.portal_searchbar">
            <t t-set="title">Machines</t>
        </t>

            <t t-call="portal.portal_table">
            <thead>
                <tr class="active">
                    <th name="machine">Machine #</th>
                    <th name="purchase_date">Purchase Date</th>
                    <th name="serial_number">Sl No.</th>
                    <th name="price">Price</th>
                    <th name="status">Status</th>
                    <th name="image">Image</th>
                </tr>
            </thead>
                <tbody>
                <t t-foreach="machine" t-as="mac">
                    <tr>

                        <td>
                            <a t-att-href="url + str(mac.id)" t-att-title="mac.name">
                                <t t-out="mac.name"/>
                            </a>
                        </td>
                            <td>
                                <span t-field="mac.date_of_purchase"/>
                            </td>
                            <td>
                                <span t-field="mac.serial_no"/>
                            </td>
                            <td>
                                <span t-field="mac.purchase_value"/>
                            </td>
                            <td>
                                <span t-field="mac.state"/>
                            </td>
                            <td>
                                <img t-att-src="'/web/image/%s/%s/image' % (mac._name, mac.id)"/>
                            </td>
                    </tr>
                     </t>
            </tbody>
        </t>
        </t>
        </template>
    <template id="website_machine_details" name="Machine Form">
           <t t-call="portal.portal_layout">
        <t t-set="breadcrumbs_searchbar" t-value="True"/>
        <t t-call="portal.portal_searchbar">
            <t t-set="title">Machine Details</t>
        </t>
          <div class="js_sale ecom-zoomable">
            <section class="oe_website_sale mt-1 mt-lg-2 mb-5 discount o_wsale_container_lg container-lg o_wsale_product_page_opt_image_width_50_pc o_wsale_product_page_opt_image_ratio_1_1 o_wsale_product_page_opt_image_ratio_mobile_auto o_wsale_product_page_opt_image_radius_none o_wsale_product_page_opt_separators">
        <div class="row align-items-lg-start" data-image_layout="carousel">
            <div class="o_wsale_product_images col o_wsale_sticky_object" style="top: 74px;">
                <div class="o_carousel_not_single carousel slide mb-3 overflow-hidden o_carousel_product_left_indicators d-flex" data-name="Product Carousel">
                    <div class="o_carousel_product_outer carousel-outer position-relative d-flex align-items-center w-100 overflow-hidden">
                        <span class="o_ribbons  z-1" style=""></span>
                        <div class="carousel-inner h-100">
                            <div class="carousel-item h-100 w-100 text-center active" style="min-height: 571px;">
                                <span class="o_ribbons o_not_editable  z-1" style=""></span>
                                <div class="d-flex align-items-center justify-content-center h-100 o_product_detail_img_wrapper oe_unmovable">
                                    <img t-att-src="image" class="img img-fluid oe_unmovable product_detail_img w-100 h-100"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="position-relative position-lg-sticky o_wsale_sticky_object col" style="top: 74px;">
                <div class="js_product js_main_product o_wsale_content_contained container">
                    <t t-foreach="machine" t-as="mac">
                    <form>
                        <div class="o_wsale_product_details_content_section o_wsale_product_details_content_section_title mb-3">
                            <h1 class="h3 mb-3" ><span t-field="mac.name"/></h1>
                        </div>
                        <div class="o_wsale_product_details_content_section o_wsale_product_details_content_section_price mb-4">
                            <div class="product_price d-inline-block decimal_precision">
                                <div class="css_editable_mode_hidden d-flex align-items-baseline justify-content-end gap-2 flex-wrap h5 mb-0 text-wrap">
                                    <span class="oe_price" style="white-space: nowrap;" data-oe-type="monetary" t-field="mac.purchase_value"></span>
                                </div>
                            </div>
                        </div>
                        <small class="text-muted mb-0">
                            <span t-field="mac.description"/>
                        </small>
                        <div class="o_wsale_product_details_content_section o_wsale_product_details_content_section_cta mb-4">
                            <div class="d-flex flex-wrap align-items-center gap-2 mb-4 w-100 w-lg-auto ">
                                <div class="d-flex flex-grow-1 flex-lg-grow-0 flex-wrap align-items-center gap-2 d-inline-flex">
                                    <a role="button" t-att-href="'/odoo/action-412/' + str(mac.id)" data-oe-model="ir.ui.view" class="btn btn-primary js_check_product a-submit flex-grow-1" >
                                        Backend
                                    </a>
                                </div>
                            </div>
                        </div>
                    </form>
                    </t>
                </div>
            </div>
        </div>
            </section>
        </div>
    </t>
    </template>
</odoo>
