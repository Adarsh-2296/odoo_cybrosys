<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template
        id="machines"
        name="Machines"
        inherit_id="portal.portal_my_home"
    >
        <div id="portal_common_category" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/portal/static/src/img/portal-addresses.svg'"/>
                <t t-set="title">Machines</t>
                <t t-set="text">View all the machines</t>
                <t t-set="url" t-value="'/website/machine'"/>
                <t t-set="config_card" t-value="True"/>
            </t>
        </div>
    </template>
    <template id="portal_machine_details" name="Machine Management Details">
        <t t-call="portal.portal_layout">
        <t t-set="breadcrumbs_searchbar" t-value="True"/>

        <t t-call="portal.portal_searchbar">
            <t t-set="title">Machines</t>
        </t>
            <t t-call="portal.portal_table">
            <thead>
                <tr class="active">
                    <th name="machine">Machine #</th>
                    <th name="purchase_date">Purchase Date</th>
                    <th name="serial_number">Sl No.</th>
                    <th name="price">Price</th>
                    <th name="status">Status</th>
                    <th name="image">Image</th>
                </tr>
            </thead>
                <tbody>
                <t t-foreach="machine" t-as="mac">
                    <tr>

                        <td>
                            <a t-att-href="url + str(mac.id)" t-att-title="mac.name">
                                <t t-out="mac.name"/>
                            </a>
                        </td>
                            <td>
                                <span t-field="mac.date_of_purchase"/>
                            </td>
                            <td>
                                <span t-field="mac.serial_no"/>
                            </td>
                            <td>
                                <span t-field="mac.purchase_value"/>
                            </td>
                            <td>
                                <span t-field="mac.state"/>
                            </td>
                            <td>
                                <img t-att-src="'/web/image/%s/%s/image' % (mac._name, mac.id)"/>
                            </td>
                    </tr>
                     </t>
            </tbody>
        </t>
        </t>
        </template>
    <template id="website_machine_details" name="Machine Form">
           <t t-call="portal.portal_layout">
        <t t-set="breadcrumbs_searchbar" t-value="True"/>
        <t t-call="portal.portal_searchbar">
            <t t-set="title">Machine Details</t>
        </t>
               <t t-foreach="machine" t-as="mac">
                   <h1> <span t-field="mac.name"/> </h1>
                   <p>
                       <b>Purchase Date:</b> <span t-field="mac.date_of_purchase"/><br/>
                       <b>Serial No:</b> <span t-field="mac.serial_no"/><br/>
                       <b>Price:</b> <span t-field="mac.purchase_value"/><br/>
                       <b>Status:</b> <span t-field="mac.state"/><br/>
                       <img t-att-src="image"/>
                   </p>
               </t>
           </t>
    </template>
</odoo>
