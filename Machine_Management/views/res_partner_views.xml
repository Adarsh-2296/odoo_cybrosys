<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="inherited_res_partner_view_form" model="ir.ui.view">
    <field name="name">res.partner.inherited.view.form</field>
    <field name="model">res.partner</field>
    <field name="inherit_id" ref="base.view_partner_form"/>
    <field name="arch" type="xml">
        <xpath expr="//div[@class='oe_button_box']" position="inside">
                    <button
                         type="object"
                         icon="fa-gears"
                         name="action_machine_smart_button">
                         <field name="machine_count"
                                   string="Machines"
                                   widget="statinfo"/>

                    </button>

            <div class="oe_button_box" name="button_box"/>
        </xpath>
        <xpath expr="//notebook" position="inside">
            <page string="Machines">
                <field name="machine_ids"/>
            </page>
        </xpath>

        </field>
    </record>
</odoo>