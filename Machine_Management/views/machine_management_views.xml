<?xml version="1.0" encoding="utf-8" ?>
<odoo>

<!--    Window view for Machine Menu-->
    <record id="action_machine_management" model="ir.actions.act_window">
        <field name="name">Machines</field>
        <field name="res_model">machine.management</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first Machine</p>
        </field>
    </record>

    <record id="action_machine_management_search_view" model="ir.ui.view">
        <field name="name">machine.management.search</field>
        <field name="model">machine.management</field>
        <field name="arch" type="xml">
                <search>
                    <filter string="Status" name="state" context="{'group_by':'state'}"/>
                    <filter string="Type" name="machine_type_id" context="{'group_by':'machine_type_id'}"/>
                    <filter string="Warranty" name="warranty" context="{'group_by':'warranty'}"/>
                    <filter string="Tag" name="tag_ids" context="{'group_by':'tag_ids'}"/>
                    <filter string="Archived" name="active" domain="[('active', '=', False)]"/>
                    <filter string="Unarchived" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Date" name="date_of_purchase" context="{'group_by':'date_of_purchase'}"/>
                </search>
        </field>
    </record>

    <record id="action_machine_management_tree_view" model="ir.ui.view">
        <field name="name">machine.management.list</field>
        <field name="model">machine.management</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'in_service'">
                <field name="name"/>
                <field name="partner_id" />
                <field name="warranty" />
                <field name="date_of_purchase" />
                <field name="purchase_value" />
                <field name="currency_id" optional="hide"/>
                <field name="active" />
            </list>
        </field>
    </record>

    <record id="action_machine_management_form_view" model="ir.ui.view">
        <field name="name">machine.management.form</field>
        <field name="model">machine.management</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button type="object" name="redirect_to_transfer" string="Transfers"/>
                    <button type="object" name="redirect_to_service" string="Service"/>
                    <field name="state" widget="statusbar" options="{'clickable':1}"/>
                </header>
                <sheet>
                    <!--                    Smart Button view-->
                 <div name="button_box"  class="oe_button_box">
                    <button
                         type="object"
                         icon="fa-exchange"
                         name="machine_transfers_smart_button">
                         <field name="transfer_count"
                                   string="Transfers"
                                   widget="statinfo"/>

                    </button>
                     <button
                         type="object"
                         icon="oi-studio"
                         name="machine_service_smart_button">
                         <field name="service_count"
                                   string="Services"
                                   widget="statinfo"/>

                    </button>
                 </div>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active != False"/>
                    <div class="oe_title">
                        <h1>
                            <field name="sequence_number" readonly="1"/>
                        </h1>
                    </div>
                        <field name="image" widget="image" class="oe_avatar"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="serial_no"/>
                            <field name="partner_id" />
                            <field name="currency_id" invisible="1"/>
                            <field name="purchase_value" />
                            <field name="company_id"/>
                            <field name="total_units"/>
                            <field name="product_filtered_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="date_of_purchase"/>
                            <field name="warranty" />
                            <field name="active" />
                            <field name="machine_type_id"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            <field name="machine_age"/>
                            <field name="service_frequency"/>
                            <field name="last_service_date"/>
                        </group>
                    </group>

                <notebook>
                    <page string="Parts">
                        <group>
                            <field
                            name="order_line_ids"
                            string=""
                            widget="sol_o2m"
                            mode="list"
                            options="{'hide_composition': True, 'hide_prices': True, 'subsections': True}"
                            >
                                <form>
                                    <group>
                                    <field name="product_id" widget="many2one_barcode" string="Product"/>
                                    <field name="quantity"/>
                                    <field name="product_uom_id"/>
                                    </group>
                                </form>
                            </field>
                        </group>
                    </page>
                    <page string="Description">
                        <field name="description"/>
                    </page>
                    <page string="Instruction">
                        <group>
                            <field name="machine_instruction"/>
                        </group>
                    </page>
                </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_machine_type" model="ir.actions.act_window">
        <field name="name">Machine Type</field>
        <field name="res_model">machine.type</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first Machine Type</p>
        </field>
    </record>

    <record id="action_machine_type_tree_view" model="ir.ui.view">
        <field name="name">machine.type.list</field>
        <field name="model">machine.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>

     <record id="action_machine_tags" model="ir.actions.act_window">
        <field name="name">Machine Tag</field>
        <field name="res_model">machine.tag</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first Machine Tag</p>
        </field>
    </record>

    <record id="action_machine_tag_tree_view" model="ir.ui.view">
        <field name="name">machine.tag.list</field>
        <field name="model">machine.tag</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

</odoo>
