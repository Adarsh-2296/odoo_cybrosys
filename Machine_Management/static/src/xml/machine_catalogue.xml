<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
   <t t-name="machine_management.dynamic_filter_template_machine">
       <section class="categories_section">
           <div class="container">
               <h3 class="section_heading">Top Machines</h3>
               <div class="categories_wrapper" style="display : flex">
                   <t t-foreach="result" t-as="mac" t-key="mac.id">
                            <div class="img_wrapper">
                               <t t-if="mac.image">
                                   <img t-att-src="'data:image/png;base64,' + mac.image"
                                        class="img img-fluid rotate-center"
                                        t-att-alt="mac.name or 'Category Image'"
                                        loading="lazy"/>
                               </t>
                           </div>
                           <div class="type" style="font-weight: 700; font-size: 20px;">
                               Machine: <t t-esc="mac.name"/><br/>
                               Price: <t t-esc="mac.purchase_value"/>
                           </div>
                   </t>
               </div>
           </div>
       </section>
   </t>
</templates>
