<templates xml:space="preserve">
    <t t-name="machine_management.dynamic_filter_template_machine">
        <div t-att-id="id" class="carousel slide" data-bs-ride="carousel" t-att-data-bs-interval="5000">
       	<div class="carousel-inner row w-100 mx-auto text-center py-5" role="listbox" aria-label="Carousel">
                <t t-foreach="result" t-as="chunk" t-key="chunk.id" >
                	<div t-att-class="chunk.is_active ? 'carousel-item active' : 'carousel-item'" role="option">
                     	<div class="s_dynamic_snippet_row row g-3">
                        	<t t-foreach="chunk" t-as="item" t-key="item.id">
                           	<div class="d-flex flex-grow-0 flex-shrink-0 col-3">
                               	<div class="oe_product_cart o_carousel_product_card d-flex">
                                   	<div class="oe_product_image position-relative flex-grow-0 overflow-hidden">
										<a t-att-href="'/website/machine/home/' + item.id">
										<t t-if="item.image">
                                        <img class="card-img-top" t-attf-src="data:image/png;base64,{{item.image}}"
                                             style="padding: 0px; margin: 0px; height: 180px; width:305px;"/>
										</t>
										<t t-else="">
                            				<div class="bg-light d-flex align-items-center justify-content-center" style="height: 180px;">
                                				<span class="text-muted">No Image</span>
											</div>
                        				</t>
										 </a>
										<div class="o_wsale_product_information flex-grow-1 flex-shrink-1">
                                        	<h5 class="mb-0"><t t-esc="item.name"/></h5>
										</div>
                                   	</div>
                               	</div>
                           	</div>
                        	</t>
                    	</div>
                	</div>
            </t>
        </div>
        </div>
        <a t-attf-href="##{id}" class="carousel-control-prev position-md-absolute w-auto" data-bs-slide="prev" role="button" aria-label="Previous" title="Previous">
        	<span class="oi oi-chevron-left ms-md-n4 rounded-pill p-3 bg-700"/>
			<span class="visually-hidden">Previous</span>
    	</a>
 		<a t-attf-href="##{id}" class="carousel-control-next position-md-absolute w-auto" data-bs-slide="next" role="button" aria-label="Next" title="Next">
        	<span class="oi oi-chevron-right me-md-n4 rounded-pill p-3 bg-700"/>
        	<span class="visually-hidden">Next</span>
    	</a>
    </t>
</templates>