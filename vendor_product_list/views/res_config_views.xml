<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_purchase_order_configuration_form_is_vendor_products" model="ir.ui.view">
        <field name="name">purchase.order.config.view.form.inherit.is_vendor.products</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="purchase.res_config_settings_view_form_purchase"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='purchase_setting_container']" position="inside">
                <group>
                    <setting id="is_vendor_products_settings" help="Set Product Domain Limit for Purchase Order Line Products" >
                        <field name="is_vendor_products_settings"/>
                    </setting>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
