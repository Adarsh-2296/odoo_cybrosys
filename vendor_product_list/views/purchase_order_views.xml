<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="purchase_order_inherited_view_vendor_productlist_form" model="ir.ui.view">
        <field name="name">purchase.order.vendor.productlis.inherited.view.form</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_ref']" position="after">
                <div invisible="is_vendor_products_settings == False">
                    <group>
                        <field name="is_vendor_products"/>
                    </group>
                </div>
            </xpath>
            <xpath expr="//field[@name='order_line']/list/field[@name='product_id']" position="attributes">
                <attribute name="domain">[('id', 'in', product_id_domain_ids)]</attribute>
            </xpath>
        </field>
    </record>
</odoo>