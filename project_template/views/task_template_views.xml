<?xml version="1.0" encoding="utf-8" ?>
<odoo>

<!--    Window view for Machine Menu-->
    <record id="action_task_template" model="ir.actions.act_window">
        <field name="name">Task</field>
        <field name="res_model">task.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first Task Template</p>
        </field>
    </record>
    <record id="action_task_template_form_view" model="ir.ui.view">
        <field name="name">task.template.form</field>
        <field name="model">task.template</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button type="object" name="action_create_task" string="Create Task" class="btn btn-primary"/>
                </header>
                <sheet>
                    <div invisible="not task_count" name="button_box"  class="oe_button_box">
                        <button
                            type="object"
                            icon="fa-puzzle-piece"
                            name="task_smart_button">
                            <field name="task_count"
                                   string="Tasks"
                                   widget="statinfo"/>

                        </button>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <h1 class="d-flex w-100">
                            <field name="name" options="{'line_breaks': False}" widget="text" class="o_task_name text-truncate w-md-75 w-100 pe-2" placeholder="Task Title..."/>
                        </h1>
                        <div class="d-flex justify-content-end align-items-center px-1" >
                            <field name="priority" class="h3 pe-2" widget="priority_switch"/>
                        </div>
                    </div>
                    <group>
                        <group>
                            <field name="project_template_id"/>
                            <field name="user_ids" widget="many2many_avatar_user"/>
                            <field name="parent_id"/>
                        </group>
                        <group>
                            <field name="partner_id"/>
                            <field name="date_deadline"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page name="sub_tasks_page" string="Sub-tasks" invisible="not project_template_id">
                            <field name="child_ids" mode="list,kanban" context="{'default_project_template_id': project_template_id,'default_user_ids': user_ids,'default_parent_id': id,'default_partner_id': partner_id,}" widget="subtasks_one2many">
                                <list editable="bottom" open_form_view="True">
                                    <field name="name" />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_task_template_list_view" model="ir.ui.view">
        <field name="name">task.template.tree</field>
        <field name="model">task.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="project_template_id"/>
                <field name="partner_id"/>
                <field name="user_ids" widget="many2many_avatar_user"/>
                <field name="date_deadline"/>
            </list>
        </field>
    </record>
</odoo>