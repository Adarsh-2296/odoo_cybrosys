<?xml version="1.0" encoding="utf-8" ?>
<odoo>

<!--    Window view for Machine Menu-->
    <record id="action_task_template" model="ir.actions.act_window">
        <field name="name">Task</field>
        <field name="res_model">task.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first Task Template</p>
        </field>
    </record>
    <record id="action_task_template_form_view" model="ir.ui.view">
        <field name="name">task.template.form</field>
        <field name="model">task.template</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button type="object" name="action_create_task" string="Create Task" class="btn btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="project_template_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>