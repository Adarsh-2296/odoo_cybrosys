<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record model="res.groups.privilege" id="res_groups_privilege_employee_transfer">
        <field name="name">Employee Transfer</field>
        <field name="description">Privilege for Employee Transfer</field>
    </record>

    <record id="group_employee_transfer_supervisor" model="res.groups">
        <field name="name">Supervisor</field>
        <field name="privilege_id" ref="res_groups_privilege_employee_transfer"/>
        <field name="user_ids" eval="[(4, ref('base.user_demo'))]"/>
    </record>
    <record id="group_employee_transfer_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="res_groups_privilege_employee_transfer"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>