<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="products_quantity" inherit_id="website_sale.products_item" name="Products Quantity">
        <xpath expr="/t/form/div" position="inside">
        <script>
            function plusFunction(clicked_id) {
            var quan = document.getElementById(clicked_id).value;
            document.getElementById(clicked_id).value = Number(quan) + 1;
            }
            function minusFunction(clicked_id) {
            var quan = document.getElementById(clicked_id).value;
            if(quan > 1){
            document.getElementById(clicked_id).value = Number(quan) - 1;
            }
            }
        </script>
      </xpath>
        <xpath expr="/t/form/div" position="after">
            <div class="d-none d-md-block mt-2 product_quantity_near_cart">
                <div class="css_quantity input-group justify-content-end h-100 border">
                <a t-att-name="product.name" onclick="minusFunction(this.name)" class="btn btn-link d-inline-block border-end-0" aria-label="Remove one" title="Remove one" >
                    <i class="oi oi-minus position-relative z-1"></i>
                </a>
                    <input t-att-id="product.name" type="text" class="js_quantity quantity form-control border-0" value="1" />
                    <a t-att-name="product.name" onclick="plusFunction(this.name)" class="btn btn-link d-inline-block border-start-0" aria-label="Add one" title="Add one"  >
                    <i class="oi oi-plus position-relative z-1"></i>
                </a>
                </div>
            </div>
        </xpath>
    </template>
</odoo>