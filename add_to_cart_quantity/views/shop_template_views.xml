<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="products_quantity" inherit_id="website_sale.products_item" name="Products Quantity">
        <div class="o_wsale_product_btn" position="inside">
            <div
                class="css_quantity input-group d-inline-flex order-first align-middle border"
                contenteditable="false"
            >
                <a
                    t-attf-href="#"
                    class="css_quantity_minus btn btn-link pe-2 js_add_cart_json border-0"
                    aria-label="Remove one"
                    title="Remove one"
                    name="remove_one"
                >
                    <i class="oi oi-minus text-600"/>
                </a>
                <input
                    type="text"
                    t-attf-class="form-control quantity text-center border-0"
                    data-min="1"
                    name="add_qty"
                    t-att-value="1"
                />
                <a
                    t-attf-href="#"
                    class="css_quantity_plus btn btn-link ps-2 js_add_cart_json border-0"
                    aria-label="Add one"
                    title="Add one"
                >
                    <i class="oi oi-plus text-600"/>
                </a>
            </div>
        </div>
    </template>
</odoo>