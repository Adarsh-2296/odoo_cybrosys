<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="products_quantity" inherit_id="website_sale.products_item" name="Products Quantity">
        <xpath expr="/t/form/div" position="inside">
        <script>
            function plusFunction() {
            var quan = document.getElementById("quantity").value;
            document.getElementById("quantity").value = Number(quan) + 1;
            console.log(quan);
            }
            function minusFunction() {
            var quan = Number(document.getElementById("quantity").value);
            if (quan > 0) {
            document.getElementById("quantity").value = quan - 1;
            }
            console.log(quan);
            }
        </script>
        </xpath>
        <xpath expr="/t/form/div/input" position="inside">
            <div
            class="product_quantity_near_cart css_quantity input-group justify-content-end h-100"

        >
                    <a onclick="minusFunction()"
                    href="#"
                       data-oe-model="ir.ui.view"
                    class="btn btn-link d-inline-block border-end-0"
                    aria-label="Remove one"
                    title="Remove one"
                >
                    <i class="oi oi-minus position-relative z-1"/>
                </a>
                <input id="quantity"
                    type="text"
                    />
<!--                    t-att-data-line-id="line.id"-->
<!--                    t-att-data-product-id="line.product_id.id"-->
<!--                    t-att-value="line._get_displayed_quantity()"-->

                <a  onclick="plusFunction()"
                    href="#"
                    data-oe-model="ir.ui.view"
                    class="btn btn-link d-inline-block border-start-0"
                    aria-label="Add one"
                    title="Add one"
                >
                    <i class="oi oi-plus position-relative z-1"/>
                </a>
                </div>
        </xpath>
    </template>
</odoo>