<?xml version="1.0" encoding="UTF-8" ?>
<templates>
   <t t-name="inventory_dashboard.InventoryDashboard">
       <div style="overflow-y : scroll; overflow-x : scroll; width: 1600px;
            height: 900px;">
           <div class="d-flex justify-content-between">
               <center>
                   <h1 style="margin:20px;">Inventory Dashboard</h1>
               </center>
               <div style="width:500px; padding:20px;">
               <div style="width:500px; padding-top:10px; padding-left:50px; box-shadow:2px 4px 8px 2px rgba(0,0,0.3,0.2);" >
                   <div class="d-flex justify-content-between" style="width:260px; padding:10px;" >
                       <div class="o-dropdown-item dropdown-item o-navigable d-flex justify-content-between o-date-filter-dropdown focus">
                            <div style="width:20px;" class="o-date-option-label">Year</div>
                            <input class="o_input"  style="width:70px; height:30px;" t-model="this.state.selectedyear" type="number" min="1900" max="2099" step="1" value="2026" t-on-change="() => this.getYear()"/>
                       </div>
                       <button style="width:100px; height:30px;  padding:2px;" class="btn btn-primary" t-on-click="() => clearFilter()">Clear</button>
                   </div>
                   <div style="width:185px; padding-bottom:10px;" class="o-dropdown-item dropdown-item o-navigable d-flex justify-content-between o-date-filter-dropdown focus">
                       <div style="width:20px;" class="o-date-option-label">Month</div>
                       <select class="o_input" style="width:100px; padding:2px;" t-model="this.state.selectedmonth" t-on-change="() => this.getMonth()">
                           <option value="1">January</option>
                           <option value="2">February</option>
                           <option value="3">March</option>
                           <option value="4">April</option>
                           <option value="5">May</option>
                           <option value="6">June</option>
                           <option value="7">July</option>
                           <option value="8">August</option>
                           <option value="9">September</option>
                           <option value="10">October</option>
                           <option value="11">November</option>
                           <option value="12">December</option>
                       </select>
                   </div>
                   <div style="width:185px;" class="o-dropdown-item dropdown-item o-navigable d-flex justify-content-between o-date-filter-dropdown focus">
                       <div style="width:20px;" class="o-date-option-label">Week</div>
                       <select class="o_input" style="width:100px; padding:2px;" t-model="this.state.selectedweek" t-on-change="() => this.getWeek()" >
                           <option value="1">Week 1</option>
                           <option value="2">Week 2</option>
                           <option value="3">Week 3</option>
                           <option value="4">Week 4</option>
                       </select>
                   </div>
               </div>
                    </div>
           </div>
           <div class="row main-section" style="margin-left: 120px;">
   <!-- Lead Tile-->
   <div id="leads" class="col-md-4 col-sm-6 tot_tasks oh-payslip"
        style=" overflow: hidden; padding-top: 30px;">
       <div class="oh-card" style="box-shadow:2px 4px 8px 2px rgba(0,0,0.3,0.2);
       display: flex; justify-content: center; height:350px;" role="button">
           <div class="oh-card-body"
                style="padding: 5px 5px; float: left; width: 100%;
                 height: auto; box-sizing: border-box; margin: 0;">
               <div class="stat-widget-one">
                   <div class="stat-icon bg-mauve-light d-flex justify-content-left align-items-left">
                       <div class="stat_content" style="
                         text-align: center; font-weight: bold;
                         padding-top: 20px; padding-left: 80px;">
                           <div class="stat_count_lead"
                                style="font-size: 17px;">
                               <span id="templates">
                                    <canvas id="group_based"/>
                               </span>
                           </div>
                           <div class="stat-head"
                                style="font-size: 14px;">Group based on picking type
                           </div>
                       </div>
                   </div>
               </div>
           </div>
       </div>
   </div>
   <!-- Opportunity Tile-->
   <div id="opportunity" class="col-md-4 col-sm-6 tot_tasks oh-payslip"
        style=" overflow: hidden; padding-top: 30px;">
       <div class="oh-card" style="box-shadow:2px 4px 8px 2px rgba(0,0,0.3,0.2);
       display: flex; justify-content: center; height:350px;" role="button">
           <div class="oh-card-body"
                style="padding: 5px 5px; float: left; width: 100%;
                 height: auto; box-sizing: border-box; margin: 0;">
               <div class="stat-widget-one">
                   <div class="stat-icon bg-mauve-light d-flex justify-content-left align-items-left">
                       <div class="stat-content" style="
                         text-align: center; font-weight: bold;
                         padding-top: 20px; padding-left: 80px;">
                           <div class="stat_count_opp"
                                style="font-size: 17px;">
                               <span id="templates">
                                    <canvas id="outgoing_data"/>
                               </span>
                           </div>
                           <div class="stat-head"
                                style="font-size: 14px;">Stock Outgoing (product wise)
                           </div>
                       </div>
                   </div>
               </div>
           </div>
       </div>
   </div>
   <!-- Expected Revenue -->
   <div id="expected_revenue"
        class="col-md-4 col-sm-6 tot_tasks oh-payslip"
        style=" overflow: hidden; padding-top: 30px;">
       <div class="oh-card" style="box-shadow:2px 4px 8px 2px rgba(0,0,0.3,0.2);
       display: flex; justify-content: center; height:350px;" role="button">
           <div class="oh-card-body"
                style="padding: 5px 5px; float: left; width: 100%;
                 height: auto; box-sizing: border-box; margin: 0;">
               <div class="stat-widget-one">
                   <div class="stat-icon bg-mauve-light d-flex justify-content-left align-items-left">
                       <div class="stat-content" style="
                         text-align: center; font-weight: bold;
                         padding-top: 20px; padding-left: 80px;">
                           <div class="stat_count_ex_rev"
                                style="font-size: 17px;">
                               <span id="templates">
                                    <canvas id="location_wise"/>
                               </span>
                           </div>
                           <div class="stat-head"
                                style="font-size: 14px;">Location wise stock info
                           </div>
                       </div>
                   </div>
               </div>
           </div>
       </div>
   </div>

</div>
