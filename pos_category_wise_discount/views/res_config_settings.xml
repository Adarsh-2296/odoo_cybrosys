<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="pos_settings_view_form_inherit_remove_order_line_pos" model="ir.ui.view">
        <field name="name">pos.settings.view.form.inherit.remove.order.line.pos</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_payment_section']" position="inside">
                        <group>
                            <setting id="pos_is_clear_order_line_button" help="Enable clear lines button in the pos" >
                                <field name="pos_is_clear_order_line_button" />
                            </setting>
                        </group>
            </xpath>
        </field>
    </record>
</odoo>