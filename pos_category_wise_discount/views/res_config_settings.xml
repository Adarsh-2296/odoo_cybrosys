<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="pos_rating_config_view_form_inherit_discount_limit" model="ir.ui.view">
        <field name="name">pos.rating.config.view.form.inherit.discount.limit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_payment_section']" position="inside">
                        <group>
                            <setting id="pos_is_restrict_payment" help="Enable discount limit for pos categories" >
                                <field name="pos_is_discount_limit" />
                                <field name="pos_category_id" widget="many2many_tags" invisible="not pos_is_discount_limit"/>
                            </setting>
                        </group>
            </xpath>
        </field>
    </record>
</odoo>
