<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="pos_category_view_form_inherit_discount_limit" model="ir.ui.view">
        <field name="name">pos.category.view.form.inherit.discount.limit</field>
        <field name="model">pos.category</field>
        <field name="inherit_id" ref="point_of_sale.product_pos_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='sequence']" position="after">
                        <group>
                            <field name="discount_limit" invisible="not is_discount_limit"/>
                        </group>
            </xpath>
        </field>
    </record>
</odoo>
