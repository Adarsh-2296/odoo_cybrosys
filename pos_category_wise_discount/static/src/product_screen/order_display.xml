<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="remove_order_line_pos.OrderDisplay" t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension">
        <div class="control-buttons d-flex justify-content-between gap-2 w-100 pt-2"  position="inside">
            <t t-if="state.is_clear_order_line">
                <button t-if="this.pos.getOrder().lines.length > 0" t-on-click="() => this.clearLines()" class="btn btn-primary">Clear Lines</button>
            </t>
        </div>
    </t>
</templates>
