<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="sale_order_inherited_view_form_vip_discount" model="ir.ui.view">
        <field name="name">sale.order.inherited.view.form.vip.discount</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_management.sale_order_form_quote"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='sale_order_template_id']" position="after">
                <div invisible="is_vip_discount== False">
                    <group>
                        <field name="is_vip"/>
                        <field name="vip_discount" invisible="is_vip == False"/>
                    </group>
                </div>
            </xpath>
        </field>
    </record>
</odoo>