<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="raccount_move_delivery_button_inherited_view_form" model="ir.ui.view">
        <field name="name">account.move.inherited.view.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                        <button invisible="delivery_count == 0" name="delivery_invoice_smart_button" class="oe_stat_button" icon="fa-truck" type="object">
                            <field name="delivery_count" widget="statinfo" string="Delivery"/>
                        </button>
            </xpath>
        </field>
    </record>
</odoo>