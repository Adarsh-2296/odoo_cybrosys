<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_rating.PopupPos">
        <Dialog title.translate="Popup-Alert">
            <div class="modal-body custom-form-view">
               <form>
                   <h1 t-out="props.title"/>
                   <p t-out="props.body"/>
                   <select t-model="this.state.selectedvalue"  style="width: 200px; height: 25px;margin: 2px; -moz-box-sizing: border-box; -webkit-box-sizing: border-box; box-sizing: border-box;">
                       <option value="Force Payment">Force Payment</option>
                       <option value="Cancel" >Cancel</option>
                 </select>
               </form>

            </div>
            <t t-set-slot="footer">
                <button class="btn btn-primary o-default-button" t-on-click="confirm">Ok</button>
            </t>
        </Dialog>
    </t>
</templates>
