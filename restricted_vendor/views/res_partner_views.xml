<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="restricted_vendor_res_partner_inherited_view_form" model="ir.ui.view">
        <field name="name">res.partner.inherited.view.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Restrict" invisible="is_vendor_restricted == False">
                    <group>
                        <field name="is_restricted"/>
                        <field name="restricted_count" invisible="is_restricted == False"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>