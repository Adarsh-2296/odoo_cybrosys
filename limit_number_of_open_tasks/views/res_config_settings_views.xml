<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_project_task_configuration_form_limit_task" model="ir.ui.view">
        <field name="name">project.task.config.view.form.inherit.limit.task</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="project.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='project_time']" position="after">
                    <block title="Tasks" name="limit_user_tasks">
                        <group>
                            <setting id="is_limit_tasks" help="Enable Task limit for the users" >
                                <field name="is_limit_tasks" />
                            </setting>
                        </group>
                    </block>
            </xpath>
        </field>
    </record>
</odoo>
