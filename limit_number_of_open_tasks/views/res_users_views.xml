<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_users_inherited_view_form_limit_tasks" model="ir.ui.view">
        <field name="name">res.users.inherited.view.form.limit.tasks</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='phone']" position="after">
                    <div invisible="is_limit_tasks == False">
                        <group>
                            <field name="max_tasks" style=" min-width: 3rem"/>
                        </group>
                    </div>
            </xpath>
        </field>
    </record>
</odoo>