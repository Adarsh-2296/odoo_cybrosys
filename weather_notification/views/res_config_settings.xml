<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="weather_notification_view_location_configuration_form" model="ir.ui.view">
        <field name="name">weather.notification.view.location.configuration.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='languages_setting_container']" position="inside">
                <group>
                    <setting id="current_location" help="Set Location for Weather" >
                        <field name="current_location"/>
                    </setting>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
